{
  "name": "discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "register": "tsx src/register-commands.ts",
    "test": "vitest run",
    "check": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "discord.js": "^14.23.2",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
